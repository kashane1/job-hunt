{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ApplicationReport",
  "type": "object",
  "required": [
    "report_id",
    "draft_id",
    "lead_id",
    "generated_at",
    "submission",
    "quality",
    "provenance_breakdown",
    "browser_metrics",
    "answers_used",
    "checkpoints",
    "blockers",
    "redaction"
  ],
  "properties": {
    "report_id": { "type": "string" },
    "draft_id": { "type": "string" },
    "lead_id": { "type": "string" },
    "generated_at": { "type": "string" },
    "submission": {
      "type": "object",
      "required": [
        "attempted",
        "submit_attempted",
        "confirmed_submitted",
        "final_submit_approval_required",
        "final_submit_approval_obtained",
        "account_creation_approval_required",
        "account_creation_approval_obtained",
        "status"
      ],
      "properties": {
        "attempted": { "type": "boolean" },
        "submit_attempted": { "type": "boolean" },
        "confirmed_submitted": { "type": "boolean" },
        "final_submit_approval_required": { "type": "boolean" },
        "final_submit_approval_obtained": { "type": "boolean" },
        "account_creation_approval_required": { "type": "boolean" },
        "account_creation_approval_obtained": { "type": "boolean" },
        "status": { "type": "string", "enum": ["submitted", "blocked", "attempted", "ambiguous", "not_started"] }
      }
    },
    "quality": {
      "type": "object",
      "required": ["application_quality_score", "confidence_band", "truthfulness_rating"],
      "properties": {
        "application_quality_score": { "type": "number" },
        "confidence_band": { "type": "string" },
        "truthfulness_rating": { "type": "string" }
      }
    },
    "provenance_breakdown": { "type": "object" },
    "browser_metrics": {
      "type": "object",
      "required": [
        "opened",
        "peak_open_tabs",
        "closed_for_budget",
        "hard_limit_hit",
        "soft_limit",
        "hard_limit"
      ],
      "properties": {
        "opened": { "type": "integer" },
        "peak_open_tabs": { "type": "integer" },
        "closed_for_budget": { "type": "integer" },
        "hard_limit_hit": { "type": "boolean" },
        "soft_limit": { "type": "integer" },
        "hard_limit": { "type": "integer" }
      }
    },
    "answers_used": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["question", "answer", "provenance", "confidence", "source_document_ids"],
        "properties": {
          "question": { "type": "string" },
          "answer": { "type": "string" },
          "provenance": { "type": "string" },
          "confidence": { "type": "number" },
          "needs_review": { "type": "boolean" },
          "source_document_ids": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "checkpoints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status", "recorded_at"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string" },
          "recorded_at": { "type": "string" }
        }
      }
    },
    "blockers": { "type": "array", "items": { "type": "string" } },
    "redaction": {
      "type": "object",
      "required": ["applied", "fields_redacted"],
      "properties": {
        "applied": { "type": "boolean" },
        "fields_redacted": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
