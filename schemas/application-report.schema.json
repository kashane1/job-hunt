{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ApplicationReport",
  "type": "object",
  "required": [
    "report_id",
    "draft_id",
    "lead_id",
    "generated_at",
    "submission",
    "quality",
    "provenance_breakdown",
    "browser_metrics"
  ],
  "properties": {
    "report_id": { "type": "string" },
    "draft_id": { "type": "string" },
    "lead_id": { "type": "string" },
    "generated_at": { "type": "string" },
    "submission": {
      "type": "object",
      "required": ["attempted", "confirmed_submitted", "approval_obtained"],
      "properties": {
        "attempted": { "type": "boolean" },
        "confirmed_submitted": { "type": "boolean" },
        "approval_obtained": { "type": "boolean" },
        "status": { "type": "string" }
      }
    },
    "quality": {
      "type": "object",
      "required": ["application_quality_score", "confidence_band", "truthfulness_rating"],
      "properties": {
        "application_quality_score": { "type": "number" },
        "confidence_band": { "type": "string" },
        "truthfulness_rating": { "type": "string" }
      }
    },
    "provenance_breakdown": { "type": "object" },
    "browser_metrics": {
      "type": "object",
      "required": ["max_open_tabs", "soft_limit", "hard_limit"],
      "properties": {
        "max_open_tabs": { "type": "integer" },
        "soft_limit": { "type": "integer" },
        "hard_limit": { "type": "integer" }
      }
    }
  }
}

