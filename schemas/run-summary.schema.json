{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RunSummary",
  "type": "object",
  "required": [
    "run_id",
    "generated_at",
    "lead_counts",
    "application_counts",
    "quality_metrics"
  ],
  "properties": {
    "run_id": { "type": "string" },
    "generated_at": { "type": "string" },
    "lead_counts": { "type": "object" },
    "application_counts": { "type": "object" },
    "quality_metrics": {
      "type": "object",
      "required": [
        "average_application_quality_score",
        "reports_count",
        "approval_records_count",
        "confirmed_submissions"
      ],
      "properties": {
        "average_application_quality_score": { "type": "number" },
        "reports_count": { "type": "integer" },
        "approval_records_count": { "type": "integer" },
        "confirmed_submissions": { "type": "integer" }
      }
    }
  }
}
