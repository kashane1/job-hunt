{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lead",
  "type": "object",
  "required": [
    "lead_id",
    "fingerprint",
    "source",
    "application_url",
    "company",
    "title",
    "location",
    "raw_description",
    "normalized_requirements",
    "status"
  ],
  "properties": {
    "lead_id": { "type": "string" },
    "fingerprint": { "type": "string" },
    "source": { "type": "string" },
    "application_url": { "type": "string" },
    "company": { "type": "string" },
    "title": { "type": "string" },
    "location": { "type": "string" },
    "compensation": { "type": "string" },
    "employment_type": { "type": "string" },
    "raw_description": { "type": "string" },
    "normalized_requirements": {
      "type": "object",
      "required": ["required", "preferred", "keywords"],
      "properties": {
        "required": { "type": "array", "items": { "type": "string" } },
        "preferred": { "type": "array", "items": { "type": "string" } },
        "keywords": { "type": "array", "items": { "type": "string" } }
      }
    },
    "fit_assessment": { "type": "object" },
    "status": { "type": "string" },
    "company_research_id": { "type": "string" },
    "application_status_path": { "type": "string" },
    "ingestion_method": { "enum": ["manual", "url_fetch_json", "url_fetch_html", "url_fetch_fallback"] },
    "ingested_at": { "type": "string" },
    "canonical_url": { "type": "string" },
    "ingestion_notes": { "type": "string" },
    "origin_board": { "type": "string" },
    "posting_url": { "type": "string" },
    "redirect_chain": {
      "type": "array",
      "items": { "type": "string" }
    },
    "discovered_via": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "company", "discovered_at"],
        "properties": {
          "source": {
            "enum": [
              "greenhouse_board",
              "lever_board",
              "careers_html",
              "careers_html_review",
              "manual"
            ]
          },
          "company": { "type": "string" },
          "discovered_at": { "type": "string" },
          "listing_updated_at": { "type": ["string", "null"] },
          "confidence": { "enum": ["high", "weak_inference"] }
        }
      }
    }
  }
}
