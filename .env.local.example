# Copy to .env.local (gitignored) and populate for local use.
#
# Batch 4 uses a dedicated Chrome profile for Indeed auto-apply. Never
# store credentials here — Indeed's session cookie lives inside the Chrome
# profile, not in the repo. Passwords/tokens/one-time codes MUST NOT land
# in any tracked file (AGENTS.md § Secret Handling).

# Path to the Chrome user-data directory that holds the logged-in Indeed
# session. The Claude-in-Chrome MCP extension drives this profile; the
# repo never reads it directly. Example (macOS):
#   JOB_HUNT_CHROME_PROFILE=/Users/you/Library/Application Support/Google/Chrome/JobHuntProfile
JOB_HUNT_CHROME_PROFILE=

# Optional: override the default Gmail search window used by
# poll-confirmations (default is apply_policy.gmail_query_window_days=14).
# JOB_HUNT_GMAIL_WINDOW_DAYS=14
